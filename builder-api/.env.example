# Builder API environment variables
# Copy to .env locally, set in Railway/Render dashboard for production.

# Port to listen on (Railway/Render override automatically)
PORT=4000

# Persistent data directory. Mount a volume here in prod so Studio writes survive deploys.
DATA_DIR=/app/data

# Comma-separated list of allowed CORS origins. Empty = open (POC only).
# Example for production:
# ALLOWED_ORIGINS=https://h5.zdn.vn,https://zalo.me,https://studio.vihat.vn
ALLOWED_ORIGINS=

NODE_ENV=production
