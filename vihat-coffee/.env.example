# Mini App Shell environment variables
# Copy to .env.production before running `zmp deploy`.

# Public URL of the Builder API. Must be HTTPS in production.
# Example after Railway deploy:
# VITE_API_BASE=https://vihat-builder-api.up.railway.app
VITE_API_BASE=https://YOUR-RAILWAY-DOMAIN.up.railway.app

# Default tenant when no ?appId= is in the URL (Zalo opens at root).
# Match this with the appId in your Builder API tenant data.
VITE_DEFAULT_APP_ID=vihat-cafe
